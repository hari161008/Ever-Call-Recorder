    <!-- Accessibility -->
    <string name="accessibility_service_summary">Enables automatic call recording</string>
    <string name="accessibility_service_description">Ever Call Recorder uses the accessibility service to reliably start recording automatically when a call comes in. No events are read — the service is only needed to allow background recording to start.</string>

    <!-- Onboarding step 5 (overlay permission) -->
    <string name="onboarding_step_overlay">Draw over other apps</string>
    <string name="onboarding_step_overlay_desc">Permission to draw over apps is needed for auto-recording from the background. We add an invisible 1×1 px layer for ~3 seconds so Android allows recording to start during a call.</string>
    <string name="onboarding_step_overlay_action">Allow</string>

    <!-- Onboarding step 6 (battery exemption) -->
    <string name="onboarding_step_battery">Keep awake</string>
    <string name="onboarding_step_battery_desc">Samsung and Pixel devices freeze apps when they are off-screen. Without this permission, Ever Call Recorder won\'t be able to wake itself up to record a call.</string>
    <string name="onboarding_step_battery_action">Allow</string>

